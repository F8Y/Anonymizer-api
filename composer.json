{
    "name": "sirius27/anonymizer-api",
    "description": "REST API module for personal data anonymization",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.0",
        "php-di/php-di": "^7.0",
        "php-di/slim-bridge": "^3.4",
        "symfony/validator": "^8.0",
        "symfony/serializer": "^8.0",
        "symfony/property-access": "^8.0",
        "symfony/property-info": "^8.0",
        "vlucas/phpdotenv": "^5.0",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "serve": "php -S 0.0.0.0:8080 -t public public/index.php",
        "test": "phpunit"
    },
    "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}